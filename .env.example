# ── Miljövariabler för Scent Privé ──────────────────────────────────────────
# Kopiera denna fil till .env och fyll i dina riktiga nycklar.
# OBS: Lägg ALDRIG .env i Git. Den är redan med i .gitignore.

# Din Stripe Secret Key (börjar med sk_live_ eller sk_test_)
# Hittas under: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=din_hemliga_nyckel_haer

# Din Stripe Publishable Key (börjar med pk_live_ eller pk_test_)
# Hittas under: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXX
